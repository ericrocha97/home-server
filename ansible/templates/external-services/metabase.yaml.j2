---
apiVersion: v1
kind: Service
metadata:
  name: metabase-external
  namespace: tools
spec:
  ports:
    - name: http
      port: 80
      protocol: TCP
---
apiVersion: discovery.k8s.io/v1
kind: EndpointSlice
metadata:
  name: metabase-external-1
  namespace: tools
  labels:
    kubernetes.io/service-name: metabase-external
addressType: IPv4
ports:
  - name: http
    port: 13001
    protocol: TCP
endpoints:
  - addresses:
      - {{ effective_server_lan_ip }}
